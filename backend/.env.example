# 덕꾸 (Deokkku) — 백엔드 환경 변수 예시
# 이 파일을 복사해 backend/.env 로 저장한 뒤 값을 채워서 사용한다.
# .env 자체는 .gitignore 로 추적 제외 상태.

# ── 필수 ────────────────────────────────────────────
# 길고 무작위적인 시크릿. 운영 배포 시 반드시 새로 발급.
DJANGO_SECRET_KEY=replace-me-with-a-long-random-secret

# True 면 개발 모드 (DEBUG 페이지, /media/ 직접 서빙).
# 배포에서는 반드시 False.
DJANGO_DEBUG=True

# 콤마로 구분된 호스트 목록. 개발: localhost,127.0.0.1 / 배포: 실제 도메인.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── 데이터베이스 ────────────────────────────────────
# 비워두면 SQLite (backend/db.sqlite3) 사용.
# 운영: postgres://USER:PASSWORD@HOST:PORT/DBNAME 형식.
DATABASE_URL=

# ── CORS / CSRF ────────────────────────────────────
# 콤마 구분. 프론트 dev 서버(5173) + 배포 도메인.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── 미디어 / 파일 업로드 ────────────────────────────
# 업로드 1건당 최대 크기 (MB). 기본 8.
MEDIA_MAX_UPLOAD_MB=8

# ── 보안 (배포 시 권장) ─────────────────────────────
# 다음 두 값은 DEBUG=False 일 때만 의미가 있음.
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
